echo "Running pre-push checks..."

current_branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
if [ "$current_branch" = "main" ]; then
  echo "❌ Direct pushes from main are blocked."
  echo "   Branch from main, open a PR, and merge via GitHub."
  echo "   To refresh local main: git fetch origin && git reset --hard origin/main"
  exit 1
fi

ORIGINAL_DATABASE_URL="${DATABASE_URL:-}"
HOOK_DATABASE_URL="${DATABASE_URL:-postgresql://dummy:dummy@localhost:5432/dhanam_hook?schema=public}"
export DATABASE_URL="$HOOK_DATABASE_URL"

# Verify formatting before spending time on heavier gates.
pnpm format:check || {
  echo "❌ Format check failed. Push aborted."
  exit 1
}

# Full type check
pnpm typecheck || {
  echo "❌ Type check failed. Push aborted."
  exit 1
}

# Run lint across entire codebase
pnpm lint || {
  echo "❌ Lint check failed. Push aborted."
  exit 1
}

# Run the unit test suite before accepting a push.
pnpm test || {
  echo "❌ Test suite failed. Push aborted."
  exit 1
}

pnpm build || {
  echo "❌ Build failed. Push aborted."
  exit 1
}

# Check if schema.prisma was modified without a migration
if git diff origin/main --name-only 2>/dev/null | grep -q "prisma/schema.prisma"; then
  MIGRATION_CHANGES=$(git diff origin/main --name-only 2>/dev/null | grep "prisma/migrations" | wc -l | tr -d ' ')
  if [ "$MIGRATION_CHANGES" -eq 0 ]; then
    echo ""
    echo "⚠️  Warning: schema.prisma modified but no new migration detected"
    echo "   Run 'cd apps/api && pnpm prisma migrate dev --name <migration_name>' to create a migration"
    echo ""
  fi
fi

# Validate Prisma schema deterministically. Live migration status requires a
# reachable database, so only run it when the caller has explicitly supplied
# DATABASE_URL instead of the hook's dummy URL.
pnpm --filter @dhanam/api exec prisma validate || {
  echo "❌ Prisma schema validation failed. Push aborted."
  exit 1
}

if [ -n "$ORIGINAL_DATABASE_URL" ]; then
  pnpm --filter @dhanam/api exec prisma migrate status || {
    echo "❌ Prisma migration status failed. Push aborted."
    exit 1
  }
else
  echo "ℹ️  DATABASE_URL not supplied; live migration status is covered by CI check-migrations."
fi

echo "✅ Pre-push checks passed"
