# Placeholder-only template. Do not commit live financial data, bank/provider payloads, account identifiers, documents, estate-planning records, webhook payloads, database URLs, provider tokens, GitHub tokens, npm tokens, or production credentials.
# Keep real values in an untracked local env file or approved secret store.

# Local side-effect guards. Set only in your shell when intentionally running local services, database mutations, destructive cleanup, or financial/provider operations.
LOCAL_SERVICES=no
LOCAL_DB=no
LOCAL_DESTRUCTIVE=no
LOCAL_FINANCIAL_OPS=no

# =============================================================================
# DHANAM - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# SHARED INFRASTRUCTURE (MADFAM Ecosystem)
# -----------------------------------------------------------------------------
# Database - Using shared PostgreSQL
DATABASE_URL=replace-with-database-url

# Redis - Using shared Redis (DB 3 for Dhanam)
REDIS_URL=replace-with-redis-url

# -----------------------------------------------------------------------------
# JANUA AUTHENTICATION
# -----------------------------------------------------------------------------
JANUA_ENABLED=true
JANUA_API_URL=http://janua-api:8001
JANUA_JWT_SECRET=replace-with-janua-jwt-secret

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# See PORT_REGISTRY.md in solarpunk-foundry for port assignments
# -----------------------------------------------------------------------------
NODE_ENV=development
WEB_PORT=3040
API_PORT=4010

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4010
NEXTAUTH_URL=http://localhost:3040
NEXTAUTH_SECRET=replace-with-nextauth-secret

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES
# -----------------------------------------------------------------------------
# Email (MailHog for development)
SMTP_HOST=dhanam-mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@dhanam.local

# Banxico (FX rates)
BANXICO_API_TOKEN=replace-with-banxico-api-token

# -----------------------------------------------------------------------------
# FINANCIAL INTEGRATIONS (Mock keys for development)
# -----------------------------------------------------------------------------
# Belvo (Mexico banking)
BELVO_SECRET_KEY_ID=replace-with-belvo-secret-key-id
BELVO_SECRET_KEY_PASSWORD=replace-with-belvo-secret-key-password
BELVO_WEBHOOK_SECRET=replace-with-belvo-webhook-secret
BELVO_ENV=replace-with-belvo-env

# Plaid (US banking)
PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET=replace-with-plaid-secret
PLAID_WEBHOOK_SECRET=replace-with-plaid-webhook-secret
PLAID_ENV=replace-with-plaid-env

# Bitso (Crypto)
BITSO_API_KEY=replace-with-bitso-api-key
BITSO_API_SECRET=replace-with-bitso-api-secret

# Zapper (DeFi portfolio — optional)
ZAPPER_API_KEY=replace-with-zapper-api-key

# -----------------------------------------------------------------------------
# BILLING (Hybrid Router: Stripe MX + Paddle Global)
# -----------------------------------------------------------------------------
# Janua Billing Integration
JANUA_BILLING_ENABLED=true
JANUA_API_KEY=replace-with-janua-api-key
JANUA_WEBHOOK_SECRET=replace-with-janua-webhook-secret
DHANAM_WEBHOOK_SECRET=replace-with-dhanam-webhook-secret

# Stripe Mexico
STRIPE_MX_SECRET_KEY=replace-with-stripe-mx-secret-key
STRIPE_MX_PUBLISHABLE_KEY=replace-with-stripe-mx-publishable-key
STRIPE_MX_WEBHOOK_SECRET=replace-with-stripe-mx-webhook-secret
STRIPE_PREMIUM_PRICE_ID=replace-with-stripe-premium-price-id

# Paddle (Global)
PADDLE_VENDOR_ID=replace-with-paddle-vendor-id
PADDLE_API_KEY=replace-with-paddle-api-key
PADDLE_CLIENT_TOKEN=replace-with-paddle-client-token
PADDLE_WEBHOOK_SECRET=replace-with-paddle-webhook-secret
PADDLE_ENVIRONMENT=replace-with-paddle-environment

# Conekta (LATAM card + SPEI direct gateway — Wave A)
# NOTE: This is the *direct* Conekta integration used by the ecosystem
# invoice flow. The Janua-routed Conekta path (JanuaBillingService) handles
# subscription lifecycle separately. Operator provisions these via the
# Wave A runbook: internal-devops/runbooks/2026-04-25-wave-a-stripe-conekta-provisioning.md
CONEKTA_PRIVATE_KEY=replace-with-conekta-private-key
CONEKTA_PUBLIC_KEY=replace-with-conekta-public-key
CONEKTA_WEBHOOK_SIGNING_KEY=replace-with-conekta-webhook-signing-key
CONEKTA_API_VERSION=replace-with-conekta-api-version

# -----------------------------------------------------------------------------
# MONITORING (Optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=
