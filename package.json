{
  "name": "dhanam",
  "version": "0.1.0",
  "private": true,
  "description": "Comprehensive budget and wealth tracking for LATAM",
  "author": "Dhanam Team",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @dhanam/api dev",
    "dev:web": "pnpm --filter @dhanam/web dev",
    "dev:admin": "pnpm --filter @dhanam/admin dev",
    "dev:mobile": "pnpm --filter @dhanam/mobile dev",
    "build": "turbo build",
    "build:packages": "turbo build --filter='./packages/*'",
    "test": "turbo test",
    "test:api": "turbo test --filter='./apps/api'",
    "test:affected": "turbo test --filter='./apps/api' -- --passWithNoTests --changedSince=HEAD~1",
    "test:precommit": "turbo test --filter='./apps/api' -- --bail --maxWorkers=2",
    "lint": "turbo lint",
    "lint:file-sizes": "node scripts/check-file-sizes.js",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "turbo db:generate",
    "db:migrate:dev": "turbo db:migrate:dev",
    "db:migrate:deploy": "turbo db:migrate:deploy",
    "db:migrate:status": "turbo db:migrate:status",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "db:studio": "turbo db:studio",
    "dev:infra": "docker compose -f infra/docker/docker-compose.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "publish:packages": "turbo publish --filter='./packages/*'"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write --check"
    ],
    "apps/api/**/*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write --check"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write --check"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^20.11.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "turbo": "2.8.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "find-my-way": ">=8.2.2",
      "path-to-regexp": ">=8.4.0",
      "glob@>=10.0.0 <10.5.0": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "axios@<1.8.0": ">=1.8.2",
      "axios@>=1.8.0 <1.15.0": ">=1.15.0",
      "validator": ">=13.15.23",
      "js-yaml": ">=4.1.1",
      "nodemailer@<7.0.9": ">=7.0.9",
      "cookie": ">=1.0.2",
      "next": "15.5.15",
      "pino": ">=10.1.0",
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7",
      "@remix-run/router": ">=1.23.2",
      "tar": ">=7.5.11",
      "diff": ">=7.0.0",
      "lodash": ">=4.18.0",
      "fast-xml-parser": ">=5.7.0",
      "fastify": ">=5.8.5",
      "@isaacs/brace-expansion": ">=5.0.1",
      "brace-expansion@>=5.0.0 <5.0.5": ">=5.0.5",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3 <3",
      "brace-expansion@>=1.0.0 <1.1.12": ">=1.1.12 <2",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "serialize-javascript": ">=7.0.3",
      "undici": ">=6.24.0",
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "dompurify": ">=3.4.0",
      "flatted": ">=3.4.2",
      "file-type": ">=21.3.2",
      "@tootallnate/once": ">=3.0.1",
      "eslint": "^9.39.0",
      "@typescript-eslint/eslint-plugin": "^8.59.0",
      "@typescript-eslint/parser": "^8.59.0",
      "@xmldom/xmldom@>=0.8.0 <0.8.13": ">=0.8.13",
      "@xmldom/xmldom@>=0.7.0 <0.8.0": ">=0.8.13",
      "@xmldom/xmldom@>=0.9.0 <0.9.10": ">=0.9.10",
      "@fastify/static@<9.1.1": ">=9.1.1",
      "follow-redirects@<1.16.0": ">=1.16.0",
      "handlebars@<4.7.9": ">=4.7.9",
      "node-forge@<1.4.0": ">=1.4.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "picomatch@>=3.0.0 <3.0.2": ">=3.0.2",
      "picomatch@>=2.0.0 <2.3.2": ">=2.3.2",
      "postcss@<8.5.10": ">=8.5.10",
      "protobufjs@>=7.0.0 <7.5.5": ">=7.5.5",
      "protobufjs@>=8.0.0 <8.0.1": ">=8.0.1",
      "uuid@<14.0.0": ">=14.0.0",
      "yaml@<2.8.3": ">=2.8.3"
    }
  }
}
