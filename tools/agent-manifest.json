{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "dhanam",
  "version": "0.1.0",
  "description": "Dhanam - MADFAM billing ledger boundary and LATAM-first personal finance app",
  "lastUpdated": "2026-05-22",

  "domains": {
    "production": {
      "api": "https://api.dhan.am",
      "app": "https://app.dhan.am",
      "admin": "https://admin.dhan.am",
      "landing": "https://dhan.am"
    }
  },

  "ports": {
    "api": 4010,
    "web": 3040,
    "admin": 3400
  },

  "kubernetes": {
    "namespace": "dhanam",
    "deployments": ["dhanam-api", "dhanam-web", "dhanam-admin"],
    "secrets": [
      "dhanam-secrets",
      "dhanam-billing-secrets",
      "dhanam-provider-secrets",
      "dhanam-janua-secrets",
      "ghcr-credentials"
    ],
    "manifests": {
      "api": "infra/k8s/production/api-deployment.yaml",
      "web": "infra/k8s/production/web-deployment.yaml",
      "admin": "infra/k8s/production/admin-deployment.yaml"
    }
  },

  "entryPoints": {
    "api": {
      "path": "apps/api/src/main.ts",
      "framework": "NestJS/Fastify",
      "healthCheck": "/v1/monitoring/health"
    },
    "web": {
      "path": "apps/web/src/app/page.tsx",
      "framework": "Next.js",
      "healthCheck": "/api/health"
    },
    "admin": {
      "path": "apps/admin/src/app/page.tsx",
      "framework": "Next.js",
      "healthCheck": "/api/health"
    }
  },

  "criticalConfiguration": {
    "ssoIntegration": {
      "path": "apps/web/src/lib/providers.tsx",
      "description": "JanuaProvider and JanuaAuthSync sync Janua SDK state with Dhanam's Zustand auth store. Login/register use @janua/react-sdk SignIn/SignUp components."
    },
    "oidcConfig": {
      "issuer": "https://auth.madfam.io",
      "clientId": "jnc_uE2zp9ume_Fd6jMl1elL6wqjiECM711t",
      "januaApiUrl": "https://api.janua.dev"
    },
    "imagePullSecrets": {
      "secretName": "ghcr-credentials",
      "description": "Required for pulling images from ghcr.io/madfam-org"
    }
  },

  "buildCommands": {
    "api": "pnpm --filter @dhanam/api build",
    "web": "pnpm --filter @dhanam/web build",
    "admin": "pnpm --filter @dhanam/admin build",
    "all": "turbo build"
  },

  "testCommands": {
    "unit": "pnpm test",
    "apiE2e": "pnpm --filter @dhanam/api test:e2e",
    "webE2e": "pnpm --dir apps/web exec playwright test --project=chromium",
    "adminE2e": "pnpm --dir apps/admin exec playwright test --project=chromium",
    "lint": "pnpm lint"
  },

  "dependencies": {
    "ecosystem": [
      {
        "name": "janua",
        "purpose": "Authentication (OIDC SSO)",
        "config": {
          "NEXT_PUBLIC_OIDC_ISSUER": "https://auth.madfam.io",
          "NEXT_PUBLIC_OIDC_CLIENT_ID": "jnc_uE2zp9ume_Fd6jMl1elL6wqjiECM711t",
          "NEXT_PUBLIC_JANUA_API_URL": "https://api.janua.dev"
        }
      },
      {
        "name": "enclii",
        "purpose": "Deployment Platform",
        "config": ".enclii.yml"
      }
    ],
    "external": ["PostgreSQL", "Redis", "Stripe", "Paddle", "Belvo", "Plaid"]
  },

  "dependents": [],

  "analytics": {
    "provider": "PostHog",
    "events": [
      "sign_up",
      "onboarding_complete",
      "connect_initiated",
      "connect_success",
      "sync_success",
      "budget_created",
      "rule_created",
      "txn_categorized",
      "alert_fired",
      "view_net_worth",
      "export_data",
      "drip_email_sent",
      "onboarding_step_completed",
      "onboarding_step_skipped",
      "connect_failed"
    ]
  },

  "authModes": {
    "envVar": "AUTH_MODE",
    "default": "janua",
    "options": ["local", "janua"],
    "interfaces": ["AuthProvider", "MfaProvider"],
    "frontendSdk": "@janua/react-sdk@0.1.3"
  },

  "llmContext": {
    "llmsTxt": "llms.txt",
    "llmsFullTxt": "llms-full.txt",
    "docsIndex": "docs/README.md",
    "roadmap": "docs/ROADMAP.md",
    "gaRemediationRoadmap": "docs/GA_REMEDIATION_ROADMAP.md",
    "stabilityAudit": "docs/STABILITY_AUDIT_2026-05-19.md",
    "techDebt": "docs/TECH_DEBT.md",
    "documentationAudit": "docs/DOCUMENTATION_AUDIT_2026-05-22.md",
    "apiModuleIndex": "apps/api/src/modules/README.md",
    "featureGuidesIndex": "docs/guides/README.md",
    "agentsMd": "AGENTS.md",
    "claudeMd": "CLAUDE.md",
    "spec": "https://llmstxt.org/",
    "webUrls": {
      "llmsTxt": "https://dhan.am/llms.txt",
      "llmsFullTxt": "https://dhan.am/llms-full.txt"
    }
  }
}
