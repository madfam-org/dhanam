# Placeholder-only template. Do not commit live financial data, bank/provider payloads, account identifiers, documents, estate-planning records, webhook payloads, database URLs, provider tokens, GitHub tokens, npm tokens, or production credentials.
# Keep real values in an untracked local env file or approved secret store.

# Local side-effect guards. Set only in your shell when intentionally running local services, database mutations, destructive cleanup, or financial/provider operations.
LOCAL_SERVICES=no
LOCAL_DB=no
LOCAL_DESTRUCTIVE=no
LOCAL_FINANCIAL_OPS=no

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8210

# Analytics (optional)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=replace-with-expo-public-posthog-host

# Feature Flags
EXPO_PUBLIC_ENABLE_ESG=true
EXPO_PUBLIC_ENABLE_CRYPTO=true

# Locale Configuration
EXPO_PUBLIC_DEFAULT_LOCALE=es # es for Spanish, en for English

# Environment
EXPO_PUBLIC_APP_ENV=development # development, staging, or production

# Sentry Error Tracking (optional)
EXPO_PUBLIC_SENTRY_DSN=

# App Configuration
EXPO_PUBLIC_APP_NAME="Dhanam"

# Push Notifications (optional)
EXPO_PUBLIC_ONESIGNAL_APP_ID=

# Deep Linking
EXPO_PUBLIC_DEEP_LINK_SCHEME=dhanam