# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4010/v1

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3040

# Janua SSO (MADFAM Identity / OIDC)
NEXT_PUBLIC_OIDC_ISSUER=https://auth.madfam.io
NEXT_PUBLIC_OIDC_CLIENT_ID=your_oidc_client_id

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
