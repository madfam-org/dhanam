# Operator-only MADFAM CSV import settings (copy to madfam-import.local.env — gitignored)
#
# Production at app.dhan.am: set TARGET_USER_EMAIL to the Janua operator account
# that already owns the madfam-csv spaces (stored in Vault / Enclii Lockbox).
#
# Do NOT commit this file with real values.

TARGET_USER_EMAIL=<operator-email-from-vault>
MADFAM_BUSINESS_RFC=<business-rfc-from-vault>

# Optional if prod already has import data — import auto-discovers spaces from
# madfam-csv-* providerAccountIds. Required for first import only:
# MADFAM_SPACE_NAME_BUSINESS=<display name>
# MADFAM_SPACE_NAME_PARTNER=<display name>
# MADFAM_SPACE_NAME_PERSONAL=<display name>

# Prod idempotency: leave unset (defaults to -afac / -personal)
# MADFAM_ACCOUNT_SUFFIX_PARTNER=-afac
# MADFAM_ACCOUNT_SUFFIX_PERSONAL=-personal

# DATABASE_URL=<prod postgres from vault>
# CSV_PATH=/path/to/export.csv
# PLATFORM_CONFIG_SOURCE=db   # read madfam.import.* from platform_config (env overrides)
