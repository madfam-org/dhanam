{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "modules/email/templates/**/*",
        "outDir": "dist"
      },
      {
        "include": "modules/billing/config/**/*.json",
        "outDir": "dist"
      }
    ],
    "watchAssets": true,
    "webpack": false,
    "tsConfigPath": "./tsconfig.json"
  }
}
