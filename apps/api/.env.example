# Database
DATABASE_URL="postgresql://dhanam_user:dhanam_pass@localhost:5432/dhanam"
# Connection pool size per API instance (default: 10)
# IMPORTANT: Total connections = pool_size * number_of_instances
# Example: 5 pool size × 10 pods = 50 connections
DATABASE_POOL_SIZE=5

# Redis (for sessions and caching)
# In production, set REDIS_URL (e.g. redis://host:6379/0).
# REDIS_HOST/REDIS_PORT/REDIS_DB are local-dev-only fallbacks.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth Mode: 'local' (self-hosted, default) or 'janua' (Galaxy ecosystem OIDC)
# Supersedes the deprecated JANUA_ENABLED flag.
AUTH_MODE=local
# JANUA_ENABLED=true  # Deprecated — use AUTH_MODE=janua instead

# JWT Configuration
# CRITICAL: Must be set in production (no fallback allowed)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-jwt-refresh-key-change-in-production"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Security Tuning (all optional — sensible defaults in code)
# REFRESH_TOKEN_EXPIRY_DAYS=30
# MAX_LOGIN_ATTEMPTS=5
# ACCOUNT_LOCKOUT_MINUTES=15
# PASSWORD_BREACH_CHECK_TIMEOUT_MS=5000
# DEMO_ACCESS_TOKEN_EXPIRY=2h
# DEMO_REFRESH_TOKEN_EXPIRY=4h
# DEMO_ACCESS_TOKEN_EXPIRY_SECONDS=7200
# HSTS_MAX_AGE_SECONDS=63072000
# SHUTDOWN_TIMEOUT_MS=5000

# Encryption (for sensitive data at rest)
# CRITICAL: Must be exactly 32 characters
ENCRYPTION_KEY="your-32-character-encryption-key"

# Demo/Seed User Passwords (only for development)
# Used by prisma/seed.ts and prisma/seed-enhanced.ts
DEMO_USER_PASSWORD="ChangeMeInProduction123!"
ADMIN_PASSWORD="AdminChangeMeInProduction123!"

# Provider Credentials
BELVO_SECRET_KEY_ID=your_belvo_secret_key_id
BELVO_SECRET_KEY_PASSWORD=your_belvo_secret_key_password
BELVO_ENVIRONMENT=sandbox # or 'production'
BELVO_WEBHOOK_SECRET=your_belvo_webhook_secret

PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENVIRONMENT=sandbox # or 'development' or 'production'
PLAID_WEBHOOK_SECRET=your_plaid_webhook_secret

BITSO_API_KEY=your_bitso_api_key
BITSO_API_SECRET=your_bitso_api_secret

# External APIs
BANXICO_API_URL=https://www.banxico.org.mx/SieAPIRest/service/v1/series
BANXICO_API_TOKEN=your_banxico_api_token

# DeFi / Alternative Data (optional)
ZAPPER_API_KEY=your_zapper_api_key
# ZILLOW_API_KEY=your_zillow_api_key  # Deprecated — see LAUNCH_OPERATIONS.md

# Collectibles Valuation (optional)
ARTSY_CLIENT_ID=
ARTSY_CLIENT_SECRET=
HAGERTY_API_KEY=

# Stripe Mexico (MX market billing)
STRIPE_MX_PUBLISHABLE_KEY=pk_test_...  # Get from Stripe Dashboard → API Keys
STRIPE_MX_SECRET_KEY=sk_test_...  # Get from Stripe Dashboard → API Keys
STRIPE_MX_WEBHOOK_SECRET=whsec_...  # Get from Stripe Dashboard → Webhooks → Signing secret
STRIPE_ESSENTIALS_PRICE_ID=price_...  # Get from Stripe Dashboard → Products
STRIPE_PREMIUM_PRICE_ID=price_...  # Get from Stripe Dashboard → Products
# Intro offer coupon: $0.99/mo for 3 months (create in Stripe Dashboard)
STRIPE_INTRO_COUPON_ID=

# Premium plan pricing
STRIPE_PREMIUM_PLAN_PRICE_ID=price_premium_monthly

# Regional discount coupons
STRIPE_PROMO_COUPON_MX=coupon_mx_promo_3mo
STRIPE_REGIONAL_COUPON_T2=coupon_regional_25pct
STRIPE_REGIONAL_COUPON_LATAM=coupon_regional_45pct
STRIPE_REGIONAL_COUPON_EMERGING=coupon_regional_65pct

# Paddle (Global market billing)
PADDLE_VENDOR_ID=  # Get from Paddle Dashboard → Developer Tools → Authentication
PADDLE_API_KEY=  # Get from Paddle Dashboard → Developer Tools → Authentication
PADDLE_CLIENT_TOKEN=  # Get from Paddle Dashboard → Developer Tools → Client-side Tokens
PADDLE_WEBHOOK_SECRET=  # Get from Paddle Dashboard → Notifications → Webhook destinations
PADDLE_ENVIRONMENT=sandbox # or 'live'

# Application URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# Email (SMTP fallback for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="noreply@dhanam.com"

# Janua Authentication (OIDC via Janua identity provider)
JANUA_JWKS_URI=https://auth.madfam.io/.well-known/jwks.json
JANUA_ISSUER=https://auth.madfam.io
JANUA_AUDIENCE=dhanam-api

# Janua Email Service (centralized Resend integration)
# When configured, emails are sent via Janua's Resend service
JANUA_API_URL=https://api.janua.dev
JANUA_INTERNAL_API_KEY=your-janua-internal-api-key

# Analytics
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://analytics.madfam.io

# Error Monitoring (Sentry)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_RELEASE=dhanam-api@0.1.0
SENTRY_ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="15 minutes"

# Logging
LOG_LEVEL=info

# API Configuration
PORT=8210
NODE_ENV=development
API_URL=http://localhost:4000/v1
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:19006"

# Janua Webhook (for receiving billing events from Janua)
JANUA_WEBHOOK_SECRET=your-janua-webhook-secret

# Dhanam Webhook Secret (for sending subscription notifications to Janua identity system)
# This enables the Enclii → Dhanam → Janua payment loop
# Must match DHANAM_WEBHOOK_SECRET in Janua's configuration
DHANAM_WEBHOOK_SECRET=your-dhanam-webhook-secret

# =============================================================================
# PhyndCRM engagement event notifier (outbound from Dhanam)
# =============================================================================
# When a Stripe MX payment envelope carries ecosystem metadata tying it
# to a PhyndCRM engagement (e.g. a Cotiza-originated milestone invoice),
# Dhanam emits a `dhanam:payment.*` event to PhyndCRM's unified
# engagement webhook so the client portal timeline updates.
# Fire-and-forget — failures are logged, never thrown. Standalone
# Dhanam subscription payments (no engagement metadata) are silent.
PHYNDCRM_API_URL=https://phynd-crm.madfam.io
# Shared ecosystem secret; same value on PhyndCRM as
# PHYND_ENGAGEMENT_EVENTS_SECRET, on Cotiza as PHYNDCRM_ENGAGEMENT_SECRET.
PHYND_ENGAGEMENT_EVENTS_SECRET=your-phyne-engagement-events-secret
PHYNDCRM_WEBHOOK_TIMEOUT=10000

# =============================================================================
# Synthetic Revenue Probe (production-only smoke test)
# =============================================================================
# When enabled, a cron self-fires a signed `probe-*` event at the live
# /v1/billing/madfam-events receiver every 5 minutes and verifies the
# Stripe → Dhanam → consumer fan-out path. Failures emit a structured ERROR
# log line `synthetic_revenue_probe_failed` and a Sentry event with tag
# `synthetic_revenue_probe_failed=true` (hook PagerDuty by tag).
#
# Default is OFF. Flip to `true` only in the production ConfigMap; staging
# and dev should leave it off so they don't probe api.dhan.am.
# Probe rows are tagged via `stripeEventId` prefix `probe-` and reaped daily
# at 04:30 UTC by a cleanup cron in the same module.
SYNTHETIC_PROBE_ENABLED=false
# Receiver base URL the probe POSTs to. Production: https://api.dhan.am
# (default if unset). Override only for cross-environment probe testing.
SYNTHETIC_PROBE_BASE_URL=https://api.dhan.am
