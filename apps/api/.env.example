# Placeholder-only template. Do not commit live financial data, bank/provider payloads, account identifiers, documents, estate-planning records, webhook payloads, database URLs, provider tokens, GitHub tokens, npm tokens, or production credentials.
# Keep real values in an untracked local env file or approved secret store.

# Local side-effect guards. Set only in your shell when intentionally running local services, database mutations, destructive cleanup, or financial/provider operations.
LOCAL_SERVICES=no
LOCAL_DB=no
LOCAL_DESTRUCTIVE=no
LOCAL_FINANCIAL_OPS=no

# Database
DATABASE_URL=replace-with-database-url
# Connection pool size per API instance (default: 10)
# IMPORTANT: Total connections = pool_size * number_of_instances
# Example: 5 pool size × 10 pods = 50 connections
DATABASE_POOL_SIZE=5

# Redis (for sessions and caching)
# In production, set REDIS_URL (e.g. redis://host:6379/0).
# REDIS_HOST/REDIS_PORT/REDIS_DB are local-dev-only fallbacks.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth Mode: 'local' (self-hosted, default) or 'janua' (Galaxy ecosystem OIDC)
# Supersedes the deprecated JANUA_ENABLED flag.
AUTH_MODE=local
# JANUA_ENABLED=true  # Deprecated — use AUTH_MODE=janua instead

# JWT Configuration
# CRITICAL: Must be set in production (no fallback allowed)
JWT_SECRET=replace-with-jwt-secret
JWT_REFRESH_SECRET=replace-with-jwt-refresh-secret
JWT_EXPIRES_IN=replace-with-jwt-expires-in
JWT_REFRESH_EXPIRES_IN=replace-with-jwt-refresh-expires-in

# Security Tuning (all optional — sensible defaults in code)
# REFRESH_TOKEN_EXPIRY_DAYS=30
# MAX_LOGIN_ATTEMPTS=5
# ACCOUNT_LOCKOUT_MINUTES=15
# PASSWORD_BREACH_CHECK_TIMEOUT_MS=5000
# DEMO_ACCESS_TOKEN_EXPIRY=2h
# DEMO_REFRESH_TOKEN_EXPIRY=4h
# DEMO_ACCESS_TOKEN_EXPIRY_SECONDS=7200
# HSTS_MAX_AGE_SECONDS=63072000
# SHUTDOWN_TIMEOUT_MS=5000

# Encryption (for sensitive data at rest)
# CRITICAL: Must be exactly 32 characters
ENCRYPTION_KEY=replace-with-encryption-key

# Demo/Seed User Passwords (only for development)
# Used by prisma/seed.ts and prisma/seed-enhanced.ts
DEMO_USER_PASSWORD=replace-with-demo-user-password
ADMIN_PASSWORD=replace-with-admin-password

# Provider Credentials
BELVO_SECRET_KEY_ID=replace-with-belvo-secret-key-id
BELVO_SECRET_KEY_PASSWORD=replace-with-belvo-secret-key-password
BELVO_ENVIRONMENT=replace-with-belvo-environment
BELVO_WEBHOOK_SECRET=replace-with-belvo-webhook-secret

PLAID_CLIENT_ID=replace-with-plaid-client-id
PLAID_SECRET=replace-with-plaid-secret
PLAID_ENVIRONMENT=replace-with-plaid-environment
PLAID_WEBHOOK_SECRET=replace-with-plaid-webhook-secret

BITSO_API_KEY=replace-with-bitso-api-key
BITSO_API_SECRET=replace-with-bitso-api-secret

# External APIs
BANXICO_API_URL=https://www.banxico.org.mx/SieAPIRest/service/v1/series
BANXICO_API_TOKEN=replace-with-banxico-api-token

# DeFi / Alternative Data (optional)
ZAPPER_API_KEY=replace-with-zapper-api-key
# ZILLOW_API_KEY=your_zillow_api_key  # Deprecated — see LAUNCH_OPERATIONS.md

# Collectibles Valuation (optional)
ARTSY_CLIENT_ID=
ARTSY_CLIENT_SECRET=
HAGERTY_API_KEY=

# Stripe Mexico (MX market billing)
STRIPE_MX_PUBLISHABLE_KEY=replace-with-stripe-mx-publishable-key
STRIPE_MX_SECRET_KEY=replace-with-stripe-mx-secret-key
STRIPE_MX_WEBHOOK_SECRET=replace-with-stripe-mx-webhook-secret
STRIPE_ESSENTIALS_PRICE_ID=replace-with-stripe-essentials-price-id
STRIPE_PREMIUM_PRICE_ID=replace-with-stripe-premium-price-id
# Intro offer coupon: $0.99/mo for 3 months (create in Stripe Dashboard)
STRIPE_INTRO_COUPON_ID=

# Premium plan pricing
STRIPE_PREMIUM_PLAN_PRICE_ID=replace-with-stripe-premium-plan-price-id

# Regional discount coupons
STRIPE_PROMO_COUPON_MX=replace-with-stripe-promo-coupon-mx
STRIPE_REGIONAL_COUPON_T2=replace-with-stripe-regional-coupon-t2
STRIPE_REGIONAL_COUPON_LATAM=replace-with-stripe-regional-coupon-latam
STRIPE_REGIONAL_COUPON_EMERGING=replace-with-stripe-regional-coupon-emerging

# Paddle (Global market billing)
PADDLE_VENDOR_ID=replace-with-paddle-vendor-id
PADDLE_API_KEY=replace-with-paddle-api-key
PADDLE_CLIENT_TOKEN=replace-with-paddle-client-token
PADDLE_WEBHOOK_SECRET=replace-with-paddle-webhook-secret
PADDLE_ENVIRONMENT=replace-with-paddle-environment

# Application URLs
WEB_URL=http://localhost:3040
API_URL=http://localhost:4010

# Email (SMTP fallback for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="noreply@dhanam.com"

# Janua Authentication (OIDC via Janua identity provider)
JANUA_JWKS_URI=https://auth.madfam.io/.well-known/jwks.json
JANUA_ISSUER=https://auth.madfam.io
JANUA_AUDIENCE=dhanam-api

# Janua Email Service (centralized Resend integration)
# When configured, emails are sent via Janua's Resend service
JANUA_API_URL=https://api.janua.dev
JANUA_INTERNAL_API_KEY=replace-with-janua-internal-api-key

# Analytics
POSTHOG_API_KEY=replace-with-posthog-api-key
POSTHOG_HOST=replace-with-posthog-host

# Error Monitoring (Sentry)
SENTRY_DSN=replace-with-sentry-dsn
SENTRY_RELEASE=replace-with-sentry-release
SENTRY_ENVIRONMENT=replace-with-sentry-environment

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="15 minutes"

# Logging
LOG_LEVEL=info

# API Configuration
PORT=4010
NODE_ENV=development
API_URL=http://localhost:4010/v1
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3040,http://localhost:3400,http://localhost:19006"

# Janua Webhook (for receiving billing events from Janua)
JANUA_WEBHOOK_SECRET=replace-with-janua-webhook-secret

# Dhanam Webhook Secret (for sending subscription notifications to Janua identity system)
# This enables the Enclii → Dhanam → Janua payment loop
# Must match DHANAM_WEBHOOK_SECRET in Janua's configuration
DHANAM_WEBHOOK_SECRET=replace-with-dhanam-webhook-secret

# =============================================================================
# PhyndCRM engagement event notifier (outbound from Dhanam)
# =============================================================================
# When a Stripe MX payment envelope carries ecosystem metadata tying it
# to a PhyndCRM engagement (e.g. a Cotiza-originated milestone invoice),
# Dhanam emits a `dhanam:payment.*` event to PhyndCRM's unified
# engagement webhook so the client portal timeline updates.
# Fire-and-forget — failures are logged, never thrown. Standalone
# Dhanam subscription payments (no engagement metadata) are silent.
PHYNDCRM_API_URL=https://phynd-crm.madfam.io
# Shared ecosystem secret; same value on PhyndCRM as
# PHYND_ENGAGEMENT_EVENTS_SECRET, on Cotiza as PHYNDCRM_ENGAGEMENT_SECRET.
PHYND_ENGAGEMENT_EVENTS_SECRET=replace-with-phynd-engagement-events-secret
PHYNDCRM_WEBHOOK_TIMEOUT=replace-with-phyndcrm-webhook-timeout

# =============================================================================
# Synthetic Revenue Probe (production-only smoke test)
# =============================================================================
# When enabled, a cron self-fires a signed `probe-*` event at the live
# /v1/billing/madfam-events receiver every 5 minutes and verifies the
# Stripe → Dhanam → consumer fan-out path. Failures emit a structured ERROR
# log line `synthetic_revenue_probe_failed` and a Sentry event with tag
# `synthetic_revenue_probe_failed=true` (hook PagerDuty by tag).
#
# Default is OFF. Flip to `true` only in the production ConfigMap; staging
# and dev should leave it off so they don't probe api.dhan.am.
# Probe rows are tagged via `stripeEventId` prefix `probe-` and reaped daily
# at 04:30 UTC by a cleanup cron in the same module.
SYNTHETIC_PROBE_ENABLED=false
# Receiver base URL the probe POSTs to. Production: https://api.dhan.am
# (default if unset). Override only for cross-environment probe testing.
SYNTHETIC_PROBE_BASE_URL=https://api.dhan.am
