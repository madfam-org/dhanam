{
  "name": "@dhanam/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node ../../scripts/require-local-services.mjs && nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:watch": "jest --config ./test/jest-e2e.json --watch",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --coverage",
    "test:e2e:onboarding": "jest --config ./test/jest-e2e.json onboarding-flow",
    "test:e2e:preferences": "jest --config ./test/jest-e2e.json preferences-management",
    "test:contract": "jest --config test/contract/jest-contract.json",
    "test:chaos": "jest --testMatch='<rootDir>/src/__tests__/chaos/**/*.chaos.spec.ts' --testPathIgnorePatterns='/node_modules/' --runInBand --forceExit",
    "test:e2e:run": "./test/e2e/run-e2e.sh",
    "test:smoke": "jest --config ./test/smoke/jest-smoke.json",
    "test:smoke:remote": "SMOKE_TEST_URL=${SMOKE_TEST_URL:-https://api.dhan.am} jest --config ./test/smoke/jest-smoke.json --testPathPattern=remote",
    "typecheck": "tsc --noEmit",
    "db:generate": "node ../../scripts/require-local-db.mjs && prisma generate",
    "db:migrate:dev": "node ../../scripts/require-local-db.mjs && prisma migrate dev",
    "db:migrate:deploy": "node ../../scripts/require-local-db.mjs && prisma migrate deploy",
    "db:migrate:status": "node ../../scripts/require-local-db.mjs && prisma migrate status",
    "db:migrate:reset": "node ../../scripts/require-local-destructive.mjs && node ../../scripts/require-local-db.mjs && prisma migrate reset",
    "db:migrate:resolve": "node ../../scripts/require-local-db.mjs && prisma migrate resolve",
    "db:push": "node ../../scripts/require-local-db.mjs && prisma db push --accept-data-loss",
    "db:seed": "node ../../scripts/require-local-db.mjs && tsx prisma/seed.ts",
    "db:seed:enhanced": "node ../../scripts/require-local-db.mjs && tsx prisma/seed-enhanced.ts",
    "db:seed:madfam": "node ../../scripts/require-local-db.mjs && tsx prisma/seed-madfam.ts",
    "db:studio": "node ../../scripts/require-local-db.mjs && prisma studio",
    "openapi:export": "node ../../scripts/require-local-financial-ops.mjs && tsx scripts/export-openapi.ts",
    "clean": "node ../../scripts/require-local-destructive.mjs && rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@dhanam/esg": "workspace:*",
    "@dhanam/shared": "workspace:*",
    "@dhanam/simulations": "workspace:*",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@sentry/node": "^10.58.0",
    "@sentry/profiling-node": "^10.58.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/belvo": "^0.16.2",
    "@types/bull": "^4.10.4",
    "@types/handlebars": "^4.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.2",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^11.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "belvo": "^0.28.0",
    "bitcoinjs-lib": "^7.0.1",
    "bull": "^4.16.5",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "fastify": "^5.7.4",
    "handlebars": "^4.7.8",
    "ioredis": "5.11.1",
    "joi": "^18.2.1",
    "js-yaml": "^4.2.0",
    "jstat": "^1.9.6",
    "jwks-rsa": "^3.2.1",
    "mx-platform-node": "^3.0.0",
    "next": "16.2.9",
    "nodemailer": "^8.0.5",
    "openai": "^6.42.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "path-to-regexp": "8.4.2",
    "pdfkit": "^0.19.1",
    "pg": "^8.21.0",
    "plaid": "^41.1.0",
    "posthog-node": "^5.37.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "speakeasy": "^2.0.0",
    "stripe": "20.4.1",
    "uuid": "^13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dhanam/config": "workspace:*",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "jest-mock-extended": "^4.0.1",
    "prettier": "^3.8.4",
    "prisma": "7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
