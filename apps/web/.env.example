# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_BASE_URL=http://localhost:3040

# Analytics (PostHog)
# Get your API key from PostHog project settings (analytics.madfam.io)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://analytics.madfam.io

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3040
NEXT_PUBLIC_DEFAULT_LOCALE=es

# Auth Mode: 'local' (self-hosted, default) or 'janua' (Galaxy ecosystem OIDC)
NEXT_PUBLIC_AUTH_MODE=local

# Janua SSO (MADFAM Identity / OIDC)
NEXT_PUBLIC_JANUA_API_URL=http://localhost:3001
NEXT_PUBLIC_JANUA_API_KEY=your_janua_api_key
NEXT_PUBLIC_OIDC_ISSUER=https://auth.madfam.io
NEXT_PUBLIC_OIDC_CLIENT_ID=your_oidc_client_id

# Billing (client-side keys)
NEXT_PUBLIC_STRIPE_MX_PUBLISHABLE_KEY=pk_test_your_stripe_mx_publishable_key
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# PMF Widget (RFC 0013) — gated until @madfam/pmf-widget publishes + is installed
# Default false; flip to true after operator runs `pnpm install @madfam/pmf-widget@^0.1.0`
NEXT_PUBLIC_PMF_WIDGET_ENABLED=false
NEXT_PUBLIC_TULANA_API_URL=https://tulana-api.madfam.io
