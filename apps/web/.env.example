# Placeholder-only template. Do not commit live financial data, bank/provider payloads, account identifiers, documents, estate-planning records, webhook payloads, database URLs, provider tokens, GitHub tokens, npm tokens, or production credentials.
# Keep real values in an untracked local env file or approved secret store.

# Local side-effect guards. Set only in your shell when intentionally running local services, database mutations, destructive cleanup, or financial/provider operations.
LOCAL_SERVICES=no
LOCAL_DB=no
LOCAL_DESTRUCTIVE=no
LOCAL_FINANCIAL_OPS=no

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4010/v1
NEXT_PUBLIC_BASE_URL=http://localhost:3040

# Analytics (PostHog)
# Get your API key from PostHog project settings (analytics.madfam.io)
NEXT_PUBLIC_POSTHOG_KEY=replace-with-next-public-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://analytics.madfam.io

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3040
NEXT_PUBLIC_DEFAULT_LOCALE=es

# Auth Mode: 'local' (self-hosted, default) or 'janua' (Galaxy ecosystem OIDC)
NEXT_PUBLIC_AUTH_MODE=local

# Janua SSO (MADFAM Identity / OIDC)
NEXT_PUBLIC_JANUA_API_URL=http://localhost:3001
NEXT_PUBLIC_JANUA_API_KEY=replace-with-next-public-janua-api-key
NEXT_PUBLIC_OIDC_ISSUER=https://auth.madfam.io
NEXT_PUBLIC_OIDC_CLIENT_ID=your_oidc_client_id

# Billing (client-side keys)
NEXT_PUBLIC_STRIPE_MX_PUBLISHABLE_KEY=replace-with-next-public-stripe-mx-publishable-key
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=replace-with-next-public-paddle-client-token
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox

# PMF Widget (RFC 0013) — gated until @madfam/pmf-widget publishes + is installed
# Default false; flip to true after operator runs `pnpm install @madfam/pmf-widget@^0.1.0`
NEXT_PUBLIC_PMF_WIDGET_ENABLED=false
NEXT_PUBLIC_TULANA_API_URL=https://tulana-api.madfam.io
